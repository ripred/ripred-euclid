{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "ripred-euclid",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "preview.html",
        "height": "tall",
        "inline": true
      },
      "game": {
        "entry": "index.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Euclid Game Post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-post",
        "postFilter": "none"
      }
    ]
  },
  "dev": {
    "subreddit": "ripred_euclid_dev"
  }
}
